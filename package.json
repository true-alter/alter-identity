{
  "name": "@truealter/sdk",
  "version": "0.2.4",
  "description": "ALTER Identity SDK — query the continuous identity field from any JavaScript/TypeScript environment. TypeScript client for mcp.truealter.com with x402 micropayments, ES256 provenance verification, and ~handle resolution.",
  "license": "Apache-2.0",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "bin": {
    "alter-identity": "./dist/bin/alter-identity.js",
    "alter-mcp-bridge": "./dist/bin/mcp-bridge.js"
  },
  "files": [
    "dist/",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@noble/ed25519": "^2.1.0",
    "@noble/hashes": "^1.4.0"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "tsup": "^8.0.2",
    "typescript": "^5.4.5",
    "vitest": "^4.1.3"
  },
  "keywords": [
    "alter",
    "identity",
    "identity-infrastructure",
    "mcp",
    "mcp-server",
    "mcp-client",
    "model-context-protocol",
    "ai-agent",
    "agent-identity",
    "x402",
    "psychometric",
    "provenance",
    "ed25519",
    "es256",
    "identity-field",
    "belonging-probability",
    "trait-vector",
    "anthropic",
    "claude"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/true-alter/alter-identity.git"
  },
  "homepage": "https://truealter.com",
  "bugs": {
    "url": "https://github.com/true-alter/alter-identity/issues"
  }
}
